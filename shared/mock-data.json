  "deploy": {
    "terraform": "# Generated by rawenv from rawenv.toml\n# Provider: Hetzner CX22\n\nresource \"hcloud_server\" \"myapp\" {\n  name        = \"myapp-prod\"\n  server_type = \"cx22\"\n  image       = \"debian-13\"\n  location    = \"fsn1\"\n  ssh_keys    = [hcloud_ssh_key.default.id]\n}",
    "ansible": "# Generated by rawenv — Ansible playbook\n\n---\n- hosts: production\n  become: true\n  tasks:\n    - name: Install rawenv\n      shell: curl -fsSL rawenv.sh/install | sh\n    - name: Copy config\n      copy: src=rawenv.toml dest=/opt/myapp/rawenv.toml\n    - name: Start services\n      shell: cd /opt/myapp && rawenv up",
    "containerfile": "FROM debian:13-slim\nRUN curl -fsSL rawenv.sh/install | sh\nCOPY rawenv.toml /app/rawenv.toml\nWORKDIR /app\nRUN rawenv init --from-toml rawenv.toml\nEXPOSE 3000 5432 6379 7700\nCMD [\"rawenv\", \"up\", \"--foreground\"]"
  }
