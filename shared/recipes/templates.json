      "files": {
        "package.json": "{\"name\":\"{project_name}\",\"version\":\"1.0.0\",\"scripts\":{\"start:dev\":\"nest start --watch\",\"build\":\"nest build\",\"start:prod\":\"node dist/main\"},\"dependencies\":{\"@nestjs/core\":\"^10.3\",\"@nestjs/common\":\"^10.3\",\"@nestjs/typeorm\":\"^10.0\",\"typeorm\":\"^0.3\",\"pg\":\"^8\"},\"engines\":{\"node\":\">=22\"}}",
        ".env": "DATABASE_URL=postgres://localhost:5432/{project_name}_dev\nREDIS_URL=redis://localhost:6379\nPORT=3000"
      }
    },
    "adonisjs": {
      "name": "AdonisJS",
      "language": "TypeScript",
      "category": "fullstack",
      "icon": "🟪",
      "description": "Full-featured Node.js MVC framework with Lucid ORM",
      "services": ["node", "postgresql", "redis"],
      "files": {
        "package.json": "{\"name\":\"{project_name}\",\"version\":\"1.0.0\",\"scripts\":{\"dev\":\"node ace serve --watch\",\"build\":\"node ace build\"},\"dependencies\":{\"@adonisjs/core\":\"^6.3\",\"@adonisjs/lucid\":\"^20\"},\"engines\":{\"node\":\">=22\"}}",
        ".env": "DB_CONNECTION=pg\nPG_HOST=localhost\nPG_PORT=5432\nPG_DB_NAME={project_name}_dev\nREDIS_HOST=localhost\nPORT=3333"
      }
