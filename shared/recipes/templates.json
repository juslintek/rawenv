      "files": {
        "go.mod": "module {project_name}\n\ngo 1.22\n\nrequire (\n\tgithub.com/gofiber/fiber/v2 v2.52.0\n\tgithub.com/go-redis/redis/v9 v9.5.1\n\tgithub.com/jackc/pgx/v5 v5.5.5\n)",
