      "files": {
        "package.json": "{\"name\":\"{project_name}\",\"version\":\"1.0.0\",\"scripts\":{\"dev\":\"next dev\",\"build\":\"next build\"},\"dependencies\":{\"next\":\"^14\",\"react\":\"^18\",\"@medusajs/medusa-js\":\"^6\"},\"engines\":{\"node\":\">=22\"}}",
