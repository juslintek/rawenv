    "axum-app": {
      "name": "Axum (Rust)",
      "language": "Rust",
      "category": "api",
      "icon": "🦀",
      "description": "Ergonomic Rust web framework built on Tokio and Tower",
      "services": ["postgresql", "redis"],
      "files": {
        "Cargo.toml": "[package]\nname = \"{project_name}\"\nversion = \"0.1.0\"\nedition = \"2021\"\n\n[dependencies]\naxum = \"0.7\"\ntokio = { version = \"1\", features = [\"full\"] }\nsqlx = { version = \"0.7\", features = [\"postgres\", \"runtime-tokio\"] }\nredis = \"0.25\"\nserde = { version = \"1\", features = [\"derive\"] }",
        ".env": "DATABASE_URL=postgres://localhost:5432/{project_name}_dev\nREDIS_URL=redis://localhost:6379\nPORT=3000"
      }
    },
    "wordpress-theme": {
      "name": "WordPress Theme Dev",
      "language": "PHP",
      "category": "fullstack",
      "icon": "📝",
      "description": "WordPress theme development environment",
      "services": ["php", "mysql", "mailpit"],
      "files": {
        "composer.json": "{\"name\":\"{project_name}\",\"require\":{\"php\":\"^8.2\"},\"require-dev\":{\"wp-cli/wp-cli\":\"^2.10\"}}",
