      "files": {
        "package.json": "{\"name\":\"{project_name}\",\"version\":\"1.0.0\",\"scripts\":{\"dev\":\"shopify app dev\",\"build\":\"remix vite:build\"},\"dependencies\":{\"@shopify/shopify-app-remix\":\"^3\",\"@remix-run/node\":\"^2\",\"@prisma/client\":\"^5\"},\"engines\":{\"node\":\">=22\"}}",
