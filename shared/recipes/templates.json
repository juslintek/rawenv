      "files": {
        "package.json": "{\"name\":\"{project_name}\",\"version\":\"1.0.0\",\"scripts\":{\"dev\":\"remix vite:dev\",\"build\":\"remix vite:build\",\"start\":\"remix-serve build/server/index.js\"},\"dependencies\":{\"@remix-run/node\":\"^2.9\",\"@remix-run/react\":\"^2.9\",\"react\":\"^18\",\"react-dom\":\"^18\"},\"engines\":{\"node\":\">=22\"}}",
        ".env": "DATABASE_URL=postgres://localhost:5432/{project_name}_dev\nREDIS_URL=redis://localhost:6379"
      }
    },
    "astro": {
      "name": "Astro",
      "language": "TypeScript",
      "category": "fullstack",
      "icon": "🚀",
      "description": "Content-focused framework with island architecture",
      "services": ["node"],
      "files": {
        "package.json": "{\"name\":\"{project_name}\",\"version\":\"1.0.0\",\"scripts\":{\"dev\":\"astro dev\",\"build\":\"astro build\",\"preview\":\"astro preview\"},\"dependencies\":{\"astro\":\"^4.10\"},\"engines\":{\"node\":\">=22\"}}",
        ".env": "PUBLIC_SITE_URL=http://localhost:4321"
      }
