        "requirements.txt": "django==5.0\ndjangorestframework==3.15.1\npsycopg2-binary==2.9\ndjango-redis==5.4\ndjango-filter==24.2\ngunicorn==22.0",
        ".env": "DATABASE_URL=postgres://localhost:5432/{project_name}_dev\nREDIS_URL=redis://localhost:6379\nSECRET_KEY=dev-secret-key"
