{
  "version": "1.0",
  "services": {
    "gitea": {
      "name": "Gitea",
      "category": "selfhosted",
      "description": "Lightweight self-hosted Git service",
      "icon": "🍵",
      "versions": ["1.22", "1.21"],
      "default_version": "1.22",
      "default_port": 3000,
      "install": {
        "macos": "curl -fsSL https://github.com/go-gitea/gitea/releases/download/v{version}.0/gitea-{version}.0-darwin-arm64 -o ~/.rawenv/store/gitea-{version}/gitea && chmod +x ~/.rawenv/store/gitea-{version}/gitea",
        "linux": "curl -fsSL https://github.com/go-gitea/gitea/releases/download/v{version}.0/gitea-{version}.0-linux-amd64 -o ~/.rawenv/store/gitea-{version}/gitea && chmod +x ~/.rawenv/store/gitea-{version}/gitea"
      },
      "start": "gitea web --port {port} --custom-path {data_dir} > {log_dir}/gitea.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "app.ini",
      "config_defaults": {"RUN_MODE": "dev", "HTTP_PORT": "{port}"},
      "plugins": {}
    },
    "forgejo": {
      "name": "Forgejo",
      "category": "selfhosted",
      "description": "Community-driven Gitea fork focused on sustainability",
      "icon": "🦊",
      "versions": ["7.0", "6.0"],
      "default_version": "7.0",
      "default_port": 3000,
      "install": {
        "macos": "curl -fsSL https://codeberg.org/forgejo/forgejo/releases/download/v{version}.0/forgejo-{version}.0-darwin-arm64 -o ~/.rawenv/store/forgejo-{version}/forgejo && chmod +x ~/.rawenv/store/forgejo-{version}/forgejo",
        "linux": "curl -fsSL https://codeberg.org/forgejo/forgejo/releases/download/v{version}.0/forgejo-{version}.0-linux-amd64 -o ~/.rawenv/store/forgejo-{version}/forgejo && chmod +x ~/.rawenv/store/forgejo-{version}/forgejo"
      },
      "start": "forgejo web --port {port} --custom-path {data_dir} > {log_dir}/forgejo.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "app.ini",
      "config_defaults": {"RUN_MODE": "dev", "HTTP_PORT": "{port}"},
      "plugins": {}
    },
    "gitlab-ce": {
      "name": "GitLab CE",
      "category": "selfhosted",
      "description": "Complete DevOps platform with CI/CD, issues, and wikis",
      "icon": "🦊",
      "versions": ["17.0", "16.11"],
      "default_version": "17.0",
      "default_port": 8080,
      "install": {
        "macos": "curl -fsSL https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.deb.sh | bash",
        "linux": "curl -fsSL https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.deb.sh | bash && apt-get install gitlab-ce={version}.0-ce.0"
      },
      "start": "gitlab-ctl start > {log_dir}/gitlab.log 2>&1 &",
      "stop": "gitlab-ctl stop",
      "init": "gitlab-ctl reconfigure",
      "config_file": "gitlab.rb",
      "config_defaults": {"external_url": "http://localhost:{port}"},
      "plugins": {}
    },
    "mattermost": {
      "name": "Mattermost",
      "category": "selfhosted",
      "description": "Open-source Slack alternative for team messaging",
      "icon": "💬",
      "versions": ["9.8", "9.7"],
      "default_version": "9.8",
      "default_port": 8065,
      "install": {
        "macos": "curl -fsSL https://releases.mattermost.com/{version}.0/mattermost-{version}.0-darwin-arm64.tar.gz | tar xz -C ~/.rawenv/store/mattermost-{version}/",
        "linux": "curl -fsSL https://releases.mattermost.com/{version}.0/mattermost-{version}.0-linux-amd64.tar.gz | tar xz -C ~/.rawenv/store/mattermost-{version}/"
      },
      "start": "cd {data_dir} && ./mattermost server > {log_dir}/mattermost.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "config.json",
      "config_defaults": {"ServiceSettings.ListenAddress": ":{port}"},
      "plugins": {}
    },
    "rocketchat": {
      "name": "Rocket.Chat",
      "category": "selfhosted",
      "description": "Open-source team communication platform",
      "icon": "🚀",
      "versions": ["6.8", "6.7"],
      "default_version": "6.8",
      "default_port": 3000,
      "install": {
        "macos": "curl -fsSL https://releases.rocket.chat/{version}/download -o /tmp/rocketchat.tgz && tar xz -C {data_dir}/ -f /tmp/rocketchat.tgz",
        "linux": "curl -fsSL https://releases.rocket.chat/{version}/download -o /tmp/rocketchat.tgz && tar xz -C {data_dir}/ -f /tmp/rocketchat.tgz"
      },
      "start": "cd {data_dir} && PORT={port} node main.js > {log_dir}/rocketchat.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": ".env",
      "config_defaults": {"MONGO_URL": "mongodb://localhost:27017/rocketchat", "PORT": "{port}"},
      "plugins": {}
    },
    "matrix-synapse": {
      "name": "Matrix Synapse",
      "category": "selfhosted",
      "description": "Decentralized communication server (Matrix protocol)",
      "icon": "🟩",
      "versions": ["1.108", "1.107"],
      "default_version": "1.108",
      "default_port": 8008,
      "install": {
        "macos": "pip install matrix-synapse=={version}.0",
        "linux": "pip install matrix-synapse=={version}.0"
      },
      "start": "synctl start {data_dir}/homeserver.yaml > {log_dir}/synapse.log 2>&1",
      "stop": "synctl stop {data_dir}/homeserver.yaml",
      "init": "python -m synapse.app.homeserver --server-name localhost --config-path {data_dir}/homeserver.yaml --generate-config --report-stats=no",
      "config_file": "homeserver.yaml",
      "config_defaults": {"server_name": "localhost", "listeners.port": "{port}"},
      "plugins": {}
    },
    "nextcloud": {
      "name": "Nextcloud",
      "category": "selfhosted",
      "description": "Self-hosted productivity platform (files, calendar, contacts)",
      "icon": "☁️",
      "versions": ["29", "28"],
      "default_version": "29",
      "default_port": 8080,
      "install": {
        "macos": "curl -fsSL https://download.nextcloud.com/server/releases/nextcloud-{version}.0.zip -o /tmp/nc.zip && unzip -q /tmp/nc.zip -d {data_dir}/",
        "linux": "curl -fsSL https://download.nextcloud.com/server/releases/nextcloud-{version}.0.tar.bz2 | tar xj -C {data_dir}/"
      },
      "start": "cd {data_dir}/nextcloud && php -S 127.0.0.1:{port} > {log_dir}/nextcloud.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "cd {data_dir}/nextcloud && php occ maintenance:install --admin-user admin --admin-pass admin",
      "config_file": "config/config.php",
      "config_defaults": {},
      "plugins": {}
    },
    "vaultwarden": {
      "name": "Vaultwarden",
      "category": "selfhosted",
      "description": "Lightweight Bitwarden-compatible password manager server",
      "icon": "🔐",
      "versions": ["1.31", "1.30"],
      "default_version": "1.31",
      "default_port": 8000,
      "install": {
        "macos": "curl -fsSL https://github.com/dani-garcia/vaultwarden/releases/download/{version}.0/vaultwarden-darwin-arm64.tar.gz | tar xz -C ~/.rawenv/store/vaultwarden-{version}/",
        "linux": "curl -fsSL https://github.com/dani-garcia/vaultwarden/releases/download/{version}.0/vaultwarden-linux-amd64.tar.gz | tar xz -C ~/.rawenv/store/vaultwarden-{version}/"
      },
      "start": "ROCKET_PORT={port} DATA_FOLDER={data_dir} vaultwarden > {log_dir}/vaultwarden.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": ".env",
      "config_defaults": {"ROCKET_PORT": "{port}", "DATA_FOLDER": "{data_dir}"},
      "plugins": {}
    },
    "plausible": {
      "name": "Plausible Analytics",
      "category": "analytics",
      "description": "Privacy-friendly Google Analytics alternative",
      "icon": "📊",
      "versions": ["2.1", "2.0"],
      "default_version": "2.1",
      "default_port": 8000,
      "install": {
        "macos": "git clone --branch v{version}.0 --depth 1 https://github.com/plausible/analytics.git {data_dir}",
        "linux": "git clone --branch v{version}.0 --depth 1 https://github.com/plausible/analytics.git {data_dir}"
      },
      "start": "cd {data_dir} && mix phx.server > {log_dir}/plausible.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "cd {data_dir} && mix setup",
      "config_file": "config/runtime.exs",
      "config_defaults": {"BASE_URL": "http://localhost:{port}"},
      "plugins": {}
    },
    "umami": {
      "name": "Umami",
      "category": "analytics",
      "description": "Simple, fast, privacy-focused web analytics",
      "icon": "📈",
      "versions": ["2.11", "2.10"],
      "default_version": "2.11",
      "default_port": 3000,
      "install": {
        "macos": "git clone --branch v{version}.0 --depth 1 https://github.com/umami-software/umami.git {data_dir}",
        "linux": "git clone --branch v{version}.0 --depth 1 https://github.com/umami-software/umami.git {data_dir}"
      },
      "start": "cd {data_dir} && npm start > {log_dir}/umami.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "cd {data_dir} && npm install && npx prisma migrate deploy",
      "config_file": ".env",
      "config_defaults": {"DATABASE_URL": "postgres://localhost:5432/umami", "PORT": "{port}"},
      "plugins": {}
    },
    "posthog": {
      "name": "PostHog",
      "category": "analytics",
      "description": "Open-source product analytics with session replay and feature flags",
      "icon": "🦔",
      "versions": ["1.43", "1.42"],
      "default_version": "1.43",
      "default_port": 8000,
      "install": {
        "macos": "git clone --branch release/{version}.0 --depth 1 https://github.com/PostHog/posthog.git {data_dir}",
        "linux": "git clone --branch release/{version}.0 --depth 1 https://github.com/PostHog/posthog.git {data_dir}"
      },
      "start": "cd {data_dir} && python manage.py runserver 0.0.0.0:{port} > {log_dir}/posthog.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "cd {data_dir} && pip install -r requirements.txt && python manage.py migrate",
      "config_file": ".env",
      "config_defaults": {"DATABASE_URL": "postgres://localhost:5432/posthog"},
      "plugins": {}
    },
    "n8n": {
      "name": "n8n",
      "category": "workflow",
      "description": "Workflow automation tool with 400+ integrations",
      "icon": "🔄",
      "versions": ["1.44", "1.43"],
      "default_version": "1.44",
      "default_port": 5678,
      "install": {
        "macos": "npm install -g n8n@{version}",
        "linux": "npm install -g n8n@{version}"
      },
      "start": "N8N_PORT={port} n8n start > {log_dir}/n8n.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": null,
      "config_defaults": {"N8N_PORT": "{port}"},
      "plugins": {}
    },
    "temporal": {
      "name": "Temporal",
      "category": "workflow",
      "description": "Durable execution platform for reliable distributed systems",
      "icon": "⏱️",
      "versions": ["1.24", "1.23"],
      "default_version": "1.24",
      "default_port": 7233,
      "install": {
        "macos": "curl -fsSL https://temporal.download/cli/archive/latest?platform=darwin&arch=arm64 | tar xz -C ~/.rawenv/store/temporal-{version}/",
        "linux": "curl -fsSL https://temporal.download/cli/archive/latest?platform=linux&arch=amd64 | tar xz -C ~/.rawenv/store/temporal-{version}/"
      },
      "start": "temporal server start-dev --port {port} --db-filename {data_dir}/temporal.db > {log_dir}/temporal.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": null,
      "config_defaults": {},
      "plugins": {}
    },
    "airflow": {
      "name": "Apache Airflow",
      "category": "workflow",
      "description": "Platform for programmatic workflow orchestration",
      "icon": "🌬️",
      "versions": ["2.9", "2.8"],
      "default_version": "2.9",
      "default_port": 8080,
      "install": {
        "macos": "pip install apache-airflow=={version}.0",
        "linux": "pip install apache-airflow=={version}.0"
      },
      "start": "airflow webserver --port {port} > {log_dir}/airflow.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "airflow db init && airflow users create --username admin --password admin --firstname Admin --lastname User --role Admin --email admin@localhost",
      "config_file": "airflow.cfg",
      "config_defaults": {"web_server_port": "{port}"},
      "plugins": {}
    },
    "prefect": {
      "name": "Prefect",
      "category": "workflow",
      "description": "Modern Python workflow orchestration framework",
      "icon": "🔷",
      "versions": ["2.19", "2.18"],
      "default_version": "2.19",
      "default_port": 4200,
      "install": {
        "macos": "pip install prefect=={version}.0",
        "linux": "pip install prefect=={version}.0"
      },
      "start": "prefect server start --port {port} > {log_dir}/prefect.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": null,
      "config_defaults": {},
      "plugins": {}
    },
    "keycloak": {
      "name": "Keycloak",
      "category": "auth",
      "description": "Open-source identity and access management by Red Hat",
      "icon": "🔑",
      "versions": ["25.0", "24.0"],
      "default_version": "25.0",
      "default_port": 8080,
      "install": {
        "macos": "curl -fsSL https://github.com/keycloak/keycloak/releases/download/{version}.0/keycloak-{version}.0.tar.gz | tar xz -C ~/.rawenv/store/keycloak-{version}/",
        "linux": "curl -fsSL https://github.com/keycloak/keycloak/releases/download/{version}.0/keycloak-{version}.0.tar.gz | tar xz -C ~/.rawenv/store/keycloak-{version}/"
      },
      "start": "cd {data_dir} && bin/kc.sh start-dev --http-port={port} > {log_dir}/keycloak.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "conf/keycloak.conf",
      "config_defaults": {"http-port": "{port}"},
      "plugins": {}
    },
    "authentik": {
      "name": "Authentik",
      "category": "auth",
      "description": "Identity provider with flows, policies, and SSO",
      "icon": "🛡️",
      "versions": ["2024.4", "2024.2"],
      "default_version": "2024.4",
      "default_port": 9000,
      "install": {
        "macos": "git clone --branch version/{version} --depth 1 https://github.com/goauthentik/authentik.git {data_dir}",
        "linux": "git clone --branch version/{version} --depth 1 https://github.com/goauthentik/authentik.git {data_dir}"
      },
      "start": "cd {data_dir} && python manage.py runserver 0.0.0.0:{port} > {log_dir}/authentik.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "cd {data_dir} && pip install -r requirements.txt && python manage.py migrate",
      "config_file": ".env",
      "config_defaults": {"AUTHENTIK_SECRET_KEY": "rawenv-dev-secret"},
      "plugins": {}
    },
    "zitadel": {
      "name": "Zitadel",
      "category": "auth",
      "description": "Cloud-native identity management with OIDC and SAML",
      "icon": "🏛️",
      "versions": ["2.54", "2.53"],
      "default_version": "2.54",
      "default_port": 8080,
      "install": {
        "macos": "curl -fsSL https://github.com/zitadel/zitadel/releases/download/v{version}.0/zitadel-darwin-arm64.tar.gz | tar xz -C ~/.rawenv/store/zitadel-{version}/",
        "linux": "curl -fsSL https://github.com/zitadel/zitadel/releases/download/v{version}.0/zitadel-linux-amd64.tar.gz | tar xz -C ~/.rawenv/store/zitadel-{version}/"
      },
      "start": "zitadel start-from-init --masterkey rawenvDevKey123456789012 --config {data_dir}/defaults.yaml --port {port} > {log_dir}/zitadel.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "defaults.yaml",
      "config_defaults": {"Port": "{port}"},
      "plugins": {}
    },
    "seaweedfs": {
      "name": "SeaweedFS",
      "category": "storage",
      "description": "Fast distributed storage system for blobs and files",
      "icon": "🌊",
      "versions": ["3.68", "3.67"],
      "default_version": "3.68",
      "default_port": 8888,
      "install": {
        "macos": "curl -fsSL https://github.com/seaweedfs/seaweedfs/releases/download/{version}/darwin_arm64.tar.gz | tar xz -C ~/.rawenv/store/seaweedfs-{version}/",
        "linux": "curl -fsSL https://github.com/seaweedfs/seaweedfs/releases/download/{version}/linux_amd64.tar.gz | tar xz -C ~/.rawenv/store/seaweedfs-{version}/"
      },
      "start": "weed server -dir={data_dir} -port={port} > {log_dir}/seaweedfs.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": null,
      "config_defaults": {},
      "plugins": {}
    },
    "garage": {
      "name": "Garage",
      "category": "storage",
      "description": "Lightweight S3-compatible distributed object storage",
      "icon": "🏠",
      "versions": ["1.0", "0.9"],
      "default_version": "1.0",
      "default_port": 3900,
      "install": {
        "macos": "curl -fsSL https://garagehq.deuxfleurs.fr/_releases/v{version}.0/aarch64-apple-darwin/garage -o ~/.rawenv/store/garage-{version}/garage && chmod +x ~/.rawenv/store/garage-{version}/garage",
        "linux": "curl -fsSL https://garagehq.deuxfleurs.fr/_releases/v{version}.0/x86_64-unknown-linux-musl/garage -o ~/.rawenv/store/garage-{version}/garage && chmod +x ~/.rawenv/store/garage-{version}/garage"
      },
      "start": "garage -c {data_dir}/garage.toml server > {log_dir}/garage.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "garage.toml",
      "config_defaults": {"s3_api.api_bind_addr": "0.0.0.0:{port}"},
      "plugins": {}
    },
    "traefik": {
      "name": "Traefik",
      "category": "proxy",
      "description": "Cloud-native reverse proxy and load balancer",
      "icon": "🔀",
      "versions": ["3.0", "2.11"],
      "default_version": "3.0",
      "default_port": 8080,
      "install": {
        "macos": "curl -fsSL https://github.com/traefik/traefik/releases/download/v{version}.0/traefik_v{version}.0_darwin_arm64.tar.gz | tar xz -C ~/.rawenv/store/traefik-{version}/",
        "linux": "curl -fsSL https://github.com/traefik/traefik/releases/download/v{version}.0/traefik_v{version}.0_linux_amd64.tar.gz | tar xz -C ~/.rawenv/store/traefik-{version}/"
      },
      "start": "traefik --configFile={data_dir}/traefik.yml > {log_dir}/traefik.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "traefik.yml",
      "config_defaults": {"api.dashboard": "true", "entryPoints.web.address": ":{port}"},
      "plugins": {}
    },
    "envoy": {
      "name": "Envoy",
      "category": "proxy",
      "description": "High-performance edge/service proxy by CNCF",
      "icon": "🌐",
      "versions": ["1.30", "1.29"],
      "default_version": "1.30",
      "default_port": 10000,
      "install": {
        "macos": "brew install envoy",
        "linux": "curl -fsSL https://github.com/envoyproxy/envoy/releases/download/v{version}.0/envoy-{version}.0-linux-x86_64 -o ~/.rawenv/store/envoy-{version}/envoy && chmod +x ~/.rawenv/store/envoy-{version}/envoy"
      },
      "start": "envoy -c {data_dir}/envoy.yaml > {log_dir}/envoy.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": null,
      "config_file": "envoy.yaml",
      "config_defaults": {},
      "plugins": {}
    },
    "haproxy": {
      "name": "HAProxy",
      "category": "proxy",
      "description": "Reliable high-performance TCP/HTTP load balancer",
      "icon": "⚖️",
      "versions": ["2.9", "2.8"],
      "default_version": "2.9",
      "default_port": 8080,
      "install": {
        "macos": "brew install haproxy",
        "linux": "curl -fsSL https://www.haproxy.org/download/{version}/src/haproxy-{version}.0.tar.gz | tar xz -C ~/.rawenv/store/haproxy-{version}/"
      },
      "start": "haproxy -f {data_dir}/haproxy.cfg -D > {log_dir}/haproxy.log 2>&1",
      "stop": "kill $(cat {data_dir}/haproxy.pid)",
      "init": null,
      "config_file": "haproxy.cfg",
      "config_defaults": {"bind": "*:{port}"},
      "plugins": {}
    },
    "influxdb": {
      "name": "InfluxDB",
      "category": "database",
      "description": "Purpose-built time-series database",
      "icon": "📉",
      "versions": ["2.7", "2.6"],
      "default_version": "2.7",
      "default_port": 8086,
      "install": {
        "macos": "curl -fsSL https://dl.influxdata.com/influxdb/releases/influxdb2-{version}.0-darwin-arm64.tar.gz | tar xz -C ~/.rawenv/store/influxdb-{version}/",
        "linux": "curl -fsSL https://dl.influxdata.com/influxdb/releases/influxdb2-{version}.0-linux-amd64.tar.gz | tar xz -C ~/.rawenv/store/influxdb-{version}/"
      },
      "start": "influxd --bolt-path={data_dir}/influxd.bolt --engine-path={data_dir}/engine --http-bind-address=:{port} > {log_dir}/influxdb.log 2>&1 &",
      "stop": "kill $(lsof -ti:{port})",
      "init": "influx setup --bucket default --org rawenv --username admin --password adminadmin --force",
      "config_file": "config.toml",
      "config_defaults": {"http-bind-address": ":{port}"},
      "plugins": {}
    },
    "clickhouse": {
      "name": "ClickHouse",
      "category": "database",
      "description": "Column-oriented OLAP database for real-time analytics",
      "icon": "🏠",
      "versions": ["24.5", "24.4"],
      "default_version": "24.5",
      "default_port": 8123,
      "install": {
        "macos": "curl -fsSL https://github.com/ClickHouse/ClickHouse/releases/download/v{version}.1.1/clickhouse-macos-aarch64 -o ~/.rawenv/store/clickhouse-{version}/clickhouse && chmod +x ~/.rawenv/store/clickhouse-{version}/clickhouse",
        "linux": "curl -fsSL https://github.com/ClickHouse/ClickHouse/releases/download/v{version}.1.1/clickhouse-linux-amd64 -o ~/.rawenv/store/clickhouse-{version}/clickhouse && chmod +x ~/.rawenv/store/clickhouse-{version}/clickhouse"
      },
      "start": "clickhouse server --config-file={data_dir}/config.xml --pid-file={data_dir}/clickhouse.pid > {log_dir}/clickhouse.log 2>&1 &",
      "stop": "kill $(cat {data_dir}/clickhouse.pid)",
      "init": null,
      "config_file": "config.xml",
      "config_defaults": {"http_port": "{port}"},
      "plugins": {}
    },
    "questdb": {
      "name": "QuestDB",
      "category": "database",
      "description": "High-performance time-series database with SQL",
      "icon": "⏰",
      "versions": ["7.4", "7.3"],
      "default_version": "7.4",
      "default_port": 9000,
      "install": {
        "macos": "curl -fsSL https://github.com/questdb/questdb/releases/download/{version}.0/questdb-{version}.0-no-jre-bin.tar.gz | tar xz -C ~/.rawenv/store/questdb-{version}/",
        "linux": "curl -fsSL https://github.com/questdb/questdb/releases/download/{version}.0/questdb-{version}.0-rt-linux-amd64.tar.gz | tar xz -C ~/.rawenv/store/questdb-{version}/"
      },
      "start": "questdb start -d {data_dir} > {log_dir}/questdb.log 2>&1 &",
      "stop": "questdb stop -d {data_dir}",
      "init": null,
      "config_file": "server.conf",
      "config_defaults": {"http.bind.to": "0.0.0.0:{port}"},
      "plugins": {}
    },
    "timescaledb": {
      "name": "TimescaleDB",
      "category": "database",
      "description": "PostgreSQL extension for time-series data at scale",
      "icon": "⏱️",
      "versions": ["2.15", "2.14"],
      "default_version": "2.15",
      "default_port": 5432,
      "install": {
        "macos": "brew install timescaledb",
        "linux": "apt-get install timescaledb-2-postgresql-16={version}"
      },
      "start": "pg_ctl -D {data_dir} -l {log_dir}/timescaledb.log start",
      "stop": "pg_ctl -D {data_dir} stop",
      "init": "initdb -D {data_dir} && timescaledb-tune --quiet --yes --pg-config={data_dir}/postgresql.conf",
      "config_file": "postgresql.conf",
      "config_defaults": {"shared_preload_libraries": "timescaledb", "port": "{port}"},
      "plugins": {}
    },
    "redpanda": {
      "name": "Redpanda",
      "category": "streaming",
      "description": "Kafka-compatible streaming platform without JVM",
      "icon": "🐼",
      "versions": ["24.1", "23.3"],
      "default_version": "24.1",
      "default_port": 9092,
      "install": {
        "macos": "brew install redpanda-data/tap/redpanda",
        "linux": "curl -fsSL https://github.com/redpanda-data/redpanda/releases/download/v{version}.1/rpk-linux-amd64.zip -o /tmp/rpk.zip && unzip -q /tmp/rpk.zip -d ~/.rawenv/store/redpanda-{version}/"
      },
      "start": "rpk redpanda start --overprovisioned --smp 1 --memory 512M --kafka-addr 0.0.0.0:{port} > {log_dir}/redpanda.log 2>&1 &",
      "stop": "rpk redpanda stop",
      "init": null,
      "config_file": "redpanda.yaml",
      "config_defaults": {"redpanda.kafka_api.address": "0.0.0.0", "redpanda.kafka_api.port": "{port}"},
      "plugins": {}
    },
    "pulsar": {
      "name": "Apache Pulsar",
      "category": "streaming",
      "description": "Distributed pub-sub messaging with multi-tenancy",
      "icon": "💫",
      "versions": ["3.3", "3.2"],
      "default_version": "3.3",
      "default_port": 6650,
      "install": {
        "macos": "curl -fsSL https://archive.apache.org/dist/pulsar/pulsar-{version}.0/apache-pulsar-{version}.0-bin.tar.gz | tar xz -C ~/.rawenv/store/pulsar-{version}/",
        "linux": "curl -fsSL https://archive.apache.org/dist/pulsar/pulsar-{version}.0/apache-pulsar-{version}.0-bin.tar.gz | tar xz -C ~/.rawenv/store/pulsar-{version}/"
      },
      "start": "bin/pulsar standalone --advertised-address localhost > {log_dir}/pulsar.log 2>&1 &",
      "stop": "bin/pulsar-daemon stop standalone",
      "init": null,
      "config_file": "conf/standalone.conf",
      "config_defaults": {"brokerServicePort": "{port}", "webServicePort": "8080"},
      "plugins": {}
    }
  }
}
