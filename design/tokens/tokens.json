{
  "color": {
    "bg": {
      "primary":   { "$value": "#0f0f14", "$type": "color", "$description": "App background" },
      "secondary": { "$value": "#16161e", "$type": "color", "$description": "Card/panel background" },
      "tertiary":  { "$value": "#1e1e2a", "$type": "color", "$description": "Input/elevated surface" },
      "hover":     { "$value": "#252535", "$type": "color", "$description": "Hover state" },
      "active":    { "$value": "#2d2d40", "$type": "color", "$description": "Active/pressed state" }
    },
    "accent": {
      "primary":   { "$value": "#6366f1", "$type": "color", "$description": "Indigo — primary actions" },
      "secondary": { "$value": "#818cf8", "$type": "color", "$description": "Lighter indigo — hover" },
      "success":   { "$value": "#34d399", "$type": "color", "$description": "Green — running/healthy" },
      "warning":   { "$value": "#fbbf24", "$type": "color", "$description": "Amber — degraded" },
      "error":     { "$value": "#f87171", "$type": "color", "$description": "Red — stopped/error" },
      "info":      { "$value": "#60a5fa", "$type": "color", "$description": "Blue — informational" }
    },
    "text": {
      "primary":   { "$value": "#e2e4f0", "$type": "color", "$description": "Primary text" },
      "secondary": { "$value": "#8b8da6", "$type": "color", "$description": "Secondary/muted text" },
      "disabled":  { "$value": "#4a4b5e", "$type": "color", "$description": "Disabled text" },
      "inverse":   { "$value": "#0f0f14", "$type": "color", "$description": "Text on accent bg" }
    },
    "border": {
      "default":   { "$value": "#2a2a3a", "$type": "color", "$description": "Default border" },
      "focus":     { "$value": "#6366f1", "$type": "color", "$description": "Focus ring" }
    },
    "tui": {
      "running":   { "$value": "#34d399", "$type": "color", "$description": "TUI green dot" },
      "stopped":   { "$value": "#f87171", "$type": "color", "$description": "TUI red dot" },
      "header":    { "$value": "#6366f1", "$type": "color", "$description": "TUI header bar" },
      "selected":  { "$value": "#1e1e2a", "$type": "color", "$description": "TUI selected row" },
      "chart_bar": { "$value": "#818cf8", "$type": "color", "$description": "TUI chart bars" }
    }
  },
  "typography": {
    "display": {
      "$value": { "fontFamily": "Inter", "fontSize": "24px", "fontWeight": 700, "lineHeight": "32px" },
      "$type": "typography", "$description": "Page titles"
    },
    "heading": {
      "$value": { "fontFamily": "Inter", "fontSize": "16px", "fontWeight": 600, "lineHeight": "24px" },
      "$type": "typography", "$description": "Section headings"
    },
    "body": {
      "$value": { "fontFamily": "Inter", "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px" },
      "$type": "typography", "$description": "Body text"
    },
    "bodyBold": {
      "$value": { "fontFamily": "Inter", "fontSize": "14px", "fontWeight": 600, "lineHeight": "20px" },
      "$type": "typography", "$description": "Emphasized body"
    },
    "caption": {
      "$value": { "fontFamily": "Inter", "fontSize": "12px", "fontWeight": 400, "lineHeight": "16px" },
      "$type": "typography", "$description": "Captions, labels"
    },
    "mono": {
      "$value": { "fontFamily": "JetBrains Mono", "fontSize": "13px", "fontWeight": 400, "lineHeight": "20px" },
      "$type": "typography", "$description": "Code, logs, ports"
    }
  },
  "spacing": {
    "xs":  { "$value": "4px",  "$type": "dimension" },
    "sm":  { "$value": "8px",  "$type": "dimension" },
    "md":  { "$value": "12px", "$type": "dimension" },
    "lg":  { "$value": "16px", "$type": "dimension" },
    "xl":  { "$value": "24px", "$type": "dimension" },
    "2xl": { "$value": "32px", "$type": "dimension" },
    "3xl": { "$value": "48px", "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "4px",   "$type": "dimension" },
    "md":   { "$value": "8px",   "$type": "dimension" },
    "lg":   { "$value": "12px",  "$type": "dimension" },
    "xl":   { "$value": "16px",  "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension" }
  },
  "shadow": {
    "sm":   { "$value": "0 1px 2px rgba(0,0,0,0.3)", "$type": "shadow" },
    "md":   { "$value": "0 4px 12px rgba(0,0,0,0.4)", "$type": "shadow" },
    "lg":   { "$value": "0 8px 24px rgba(0,0,0,0.5)", "$type": "shadow" }
  }
}
