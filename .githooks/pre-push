#!/usr/bin/env bash
# shellcheck disable=SC2154  # arrays populated via eval in collect_* helpers
# pre-push — quality gate. Format checks, strict lint on changed files, and the
# full build + test suites for every platform whose toolchain is present.
# Platforms whose tools are absent (Vala/Linux, .NET on macOS) are skipped with a
# notice rather than failing. Written for bash 3.2 (no mapfile/assoc arrays).
#
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

ok()   { printf '\033[0;32m[pre-push]\033[0m %s\n' "$*"; }
note() { printf '\033[0;36m[pre-push]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[pre-push]\033[0m %s\n' "$*"; }
err()  { printf '\033[0;31m[pre-push]\033[0m %s\n' "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

fail=0
step() { # step <label> <cmd...>
  local label="$1"; shift
  note "$label"
  if "$@"; then ok "✓ $label"; else err "✗ $label"; fail=1; fi
}

# Scope "changed files" lint to this push's work (merge-base with upstream).
UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "origin/main")"
BASE="$(git merge-base "$UPSTREAM" HEAD 2>/dev/null || true)"

# collect_changed <var> <glob...> — fill array <var> with changed, present files.
collect_changed() {
  local __var="$1"; shift
  local __f
  eval "$__var=()"
  if [ -n "$BASE" ]; then
    while IFS= read -r __f; do
      [ -n "$__f" ] && [ -f "$__f" ] && eval "$__var+=(\"\$__f\")"
    done < <(git diff --name-only --diff-filter=ACM "$BASE"...HEAD -- "$@" 2>/dev/null)
  fi
}

# 1. Formatting gates (deterministic — must be clean).
have zig && step "zig fmt --check" zig fmt --check src/ tests/ build.zig

collect_changed swift_changed '*.swift'
if [ "${#swift_changed[@]}" -gt 0 ] && swift format --version >/dev/null 2>&1; then
  step "swift format lint (changed)" swift format lint --strict --configuration "$ROOT/.swift-format" "${swift_changed[@]}"
fi

# 2. Strict lint on CHANGED files (new code held strict; existing backlog doesn't block).
if [ "${#swift_changed[@]}" -gt 0 ] && have swiftlint; then
  step "swiftlint (changed, error-gated)" swiftlint lint --quiet --config "$ROOT/.swiftlint.yml" "${swift_changed[@]}"
fi

collect_changed sh_changed '*.sh' '*.bash'
if [ "${#sh_changed[@]}" -gt 0 ] && have shellcheck; then
  step "shellcheck (changed)" shellcheck -x --severity=warning "${sh_changed[@]}"
fi

collect_changed yaml_changed '*.yml' '*.yaml'
if [ "${#yaml_changed[@]}" -gt 0 ] && have yamllint; then
  step "yamllint (changed)" yamllint -c "$ROOT/.yamllint" "${yaml_changed[@]}"
fi

# 3. Zig core build + tests (always; cross-platform).
if have zig; then
  step "zig build" zig build
  step "zig build test" zig build test
else
  warn "zig not found — skipping core build/tests"
fi

# 4. macOS Swift GUI (unit/feature/functional/integration). UI e2e stays gated.
if [ "$(uname -s)" = "Darwin" ] && have swift; then
  step "swift test (macOS GUI)" bash -c 'cd gui/macos && swift test'
else
  warn "not macOS or swift missing — skipping Swift GUI tests"
fi

# 5. Windows C# GUI unit tests (the cross-platform-buildable part).
if have dotnet; then
  step "dotnet test (Windows GUI unit)" bash -c 'cd gui/windows && dotnet test Rawenv.Tests/Rawenv.Tests.csproj --nologo'
else
  warn "dotnet not found — skipping Windows GUI tests (run in CI on windows-latest)"
fi

# 6. Linux GTK4/Vala GUI (meson) — only where the toolchain exists.
if have meson && have valac; then
  step "meson test (Linux GUI)" bash -c 'cd gui/linux && (meson setup build >/dev/null 2>&1 || meson setup --reconfigure build >/dev/null 2>&1); ninja -C build >/dev/null && meson test -C build'
else
  warn "meson/valac not found — skipping Linux GUI tests (run in CI on ubuntu)"
fi

# 7. Quality guardrails: review-lesson anti-patterns on changed files.
. "$ROOT/.githooks/quality-guards.sh"
collect_changed qg_changed '*'
if [ "${#qg_changed[@]}" -gt 0 ]; then
  step "quality guardrails" quality_guards "${qg_changed[@]}"
fi

if [ "$fail" -ne 0 ]; then
  err "push blocked by failing checks. Fix the cause — do not bypass hooks."
  exit 1
fi
ok "all checks passed — pushing."
exit 0
