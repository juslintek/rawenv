#!/usr/bin/env bash
# shellcheck disable=SC2154  # arrays populated via eval in collect_* helpers
# pre-commit — auto-format and lint-fix STAGED files, then re-stage them.
# Fast by design: formats only what you're committing, never the whole tree.
# Missing tools are skipped with a notice (see .githooks/install.sh to add them).
# Written for bash 3.2 (macOS default): no `mapfile`, no associative arrays.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

note() { printf '\033[0;36m[pre-commit]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[pre-commit]\033[0m %s\n' "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

# collect_staged <var> <glob...> — fill array <var> with staged, present files.
collect_staged() {
  local __var="$1"; shift
  local __f
  eval "$__var=()"
  while IFS= read -r __f; do
    [ -n "$__f" ] && [ -f "$__f" ] && eval "$__var+=(\"\$__f\")"
  done < <(git diff --cached --name-only --diff-filter=ACM -- "$@" 2>/dev/null)
}

restage=()

# --- Zig: zig fmt (deterministic) -----------------------------------------
collect_staged zig_files '*.zig'
if [ "${#zig_files[@]}" -gt 0 ] && have zig; then
  note "zig fmt (${#zig_files[@]} file/s)"
  zig fmt "${zig_files[@]}" >/dev/null 2>&1 || true
  restage+=("${zig_files[@]}")
fi

# --- Swift: swift format -i + swiftlint --fix -----------------------------
collect_staged swift_files '*.swift'
if [ "${#swift_files[@]}" -gt 0 ]; then
  if swift format --version >/dev/null 2>&1; then
    note "swift format (${#swift_files[@]} file/s)"
    swift format -i --configuration "$ROOT/.swift-format" "${swift_files[@]}" >/dev/null 2>&1 || true
  else
    warn "swift format unavailable — skipping Swift formatting"
  fi
  if have swiftlint; then
    note "swiftlint --fix"
    swiftlint --fix --quiet --config "$ROOT/.swiftlint.yml" "${swift_files[@]}" >/dev/null 2>&1 || true
  fi
  restage+=("${swift_files[@]}")
fi

# --- Shell: shfmt -w ------------------------------------------------------
collect_staged sh_files '*.sh' '*.bash'
if [ "${#sh_files[@]}" -gt 0 ] && have shfmt; then
  note "shfmt (${#sh_files[@]} file/s)"
  shfmt -w -i 2 -ci "${sh_files[@]}" >/dev/null 2>&1 || true
  restage+=("${sh_files[@]}")
fi

# --- C#: dotnet format (if available) -------------------------------------
collect_staged cs_files '*.cs'
if [ "${#cs_files[@]}" -gt 0 ] && have dotnet; then
  note "dotnet format (changed C# files)"
  ( cd gui/windows 2>/dev/null && dotnet format Rawenv.sln --no-restore >/dev/null 2>&1 ) || true
  restage+=("${cs_files[@]}")
fi

# Re-stage anything we touched so the fixes are part of THIS commit.
if [ "${#restage[@]}" -gt 0 ]; then
  git add -- "${restage[@]}" 2>/dev/null || true
fi

# --- Lint gate (fast; auto-fixable issues already applied above) ----------
fail=0

collect_staged sh_now '*.sh' '*.bash'
if [ "${#sh_now[@]}" -gt 0 ] && have shellcheck; then
  shellcheck -x --severity=warning "${sh_now[@]}" || { warn "shellcheck warnings/errors above"; fail=1; }
fi

collect_staged yaml_now '*.yml' '*.yaml'
if [ "${#yaml_now[@]}" -gt 0 ] && have yamllint; then
  yamllint -c "$ROOT/.yamllint" "${yaml_now[@]}" || { warn "yamllint issues above"; fail=1; }
fi

if [ "$fail" -ne 0 ]; then
  warn "commit blocked by lint errors. Fix + re-stage, or 'git commit --no-verify' to bypass."
  exit 1
fi
exit 0
