<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background tokens -->
    <SolidColorBrush x:Key="BgPrimary" Color="#0f0f14"/>
    <SolidColorBrush x:Key="BgSecondary" Color="#16161e"/>
    <SolidColorBrush x:Key="BgTertiary" Color="#1e1e2a"/>
    <SolidColorBrush x:Key="BgElevated" Color="#252536"/>

    <!-- Accent tokens -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#6366f1"/>
    <SolidColorBrush x:Key="AccentSuccess" Color="#34d399"/>
    <SolidColorBrush x:Key="AccentError" Color="#f87171"/>
    <SolidColorBrush x:Key="AccentWarning" Color="#fbbf24"/>
    <SolidColorBrush x:Key="AccentInfo" Color="#60a5fa"/>

    <!-- Text tokens -->
    <SolidColorBrush x:Key="TextPrimary" Color="#e2e4f0"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#8b8da6"/>
    <SolidColorBrush x:Key="TextMuted" Color="#4a4b5e"/>

    <!-- Border tokens -->
    <SolidColorBrush x:Key="BorderDefault" Color="#2a2a3a"/>
    <SolidColorBrush x:Key="BorderSubtle" Color="#1e1e2a"/>

    <!-- Spacing / Radius -->
    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">10</CornerRadius>
    <CornerRadius x:Key="RadiusXl">12</CornerRadius>

    <Thickness x:Key="SpacingSm">8</Thickness>
    <Thickness x:Key="SpacingMd">16</Thickness>
    <Thickness x:Key="SpacingLg">24</Thickness>
</ResourceDictionary>
