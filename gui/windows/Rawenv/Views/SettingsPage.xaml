<Page
    x:Class="Rawenv.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark"
    Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0f0f14"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#16161e"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#1e1e2a"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentSuccess" Color="#34d399"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e2e4f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8b8da6"/>
        <SolidColorBrush x:Key="BorderDefault" Color="#2a2a3a"/>
    </Page.Resources>

    <Grid Background="{StaticResource BgPrimary}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Settings Sidebar -->
        <Border Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,1,0">
            <ListView x:Name="SettingsNav" Padding="8" SelectionChanged="SettingsNav_SelectionChanged"
                      AutomationProperties.AutomationId="SettingsNavigation">
                <ListViewItem Content="General" Tag="General" IsSelected="True"/>
                <ListViewItem Content="Services" Tag="Services"/>
                <ListViewItem Content="Runtimes" Tag="Runtimes"/>
                <ListViewItem Content="Network" Tag="Network"/>
                <ListViewItem Content="Cells" Tag="Cells"/>
                <ListViewItem Content="Deploy" Tag="Deploy"/>
                <ListViewItem Content="AI" Tag="AI"/>
                <ListViewItem Content="Theme" Tag="Theme"/>
                <ListViewItem Content="About" Tag="About"/>
            </ListView>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Column="1" Padding="24">
            <Grid>
                <!-- General -->
                <StackPanel x:Name="GeneralPanel" Spacing="16" AutomationProperties.AutomationId="SettingsGeneral">
                    <TextBlock Text="General" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Store Location" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="StoreLocationBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <ToggleSwitch x:Name="AutoStartToggle" Header="Auto-start services" OnContent="On" OffContent="Off"/>
                        <ToggleSwitch x:Name="AutoDetectToggle" Header="Auto-detect projects" OnContent="On" OffContent="Off"/>
                        <ToggleSwitch x:Name="LaunchAtLoginToggle" Header="Launch at login" OnContent="On" OffContent="Off"/>
                        <ToggleSwitch x:Name="FileWatcherToggle" Header="File watcher" OnContent="On" OffContent="Off"/>
                        <TextBlock Text="Scan Paths" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="ScanPathsBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}" AcceptsReturn="True" Height="60"/>
                    </StackPanel>
                </StackPanel>

                <!-- Services -->
                <StackPanel x:Name="ServicesPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsServices">
                    <TextBlock Text="Services" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <ToggleSwitch Header="Auto-restart on crash" OnContent="On" OffContent="Off" IsOn="True"/>
                        <TextBlock Text="Max restart attempts" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <NumberBox SpinButtonPlacementMode="Compact" Minimum="1" Maximum="10" Value="3"/>
                        <ToggleSwitch Header="Health checks" OnContent="On" OffContent="Off" IsOn="True"/>
                        <TextBlock Text="Health check interval (s)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <NumberBox SpinButtonPlacementMode="Compact" Minimum="5" Maximum="300" Value="30"/>
                        <ToggleSwitch Header="Log to file" OnContent="On" OffContent="Off"/>
                        <TextBlock Text="Log retention (days)" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <NumberBox SpinButtonPlacementMode="Compact" Minimum="1" Maximum="90" Value="7"/>
                    </StackPanel>
                </StackPanel>

                <!-- Runtimes -->
                <StackPanel x:Name="RuntimesPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsRuntimes">
                    <TextBlock Text="Runtimes" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <ToggleSwitch Header="Auto-update runtimes" OnContent="On" OffContent="Off"/>
                        <ToggleSwitch Header="Verify SHA256 checksums" OnContent="On" OffContent="Off" IsOn="True"/>
                        <TextBlock Text="Download mirror" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}" PlaceholderText="https://releases.rawenv.sh"/>
                        <TextBlock Text="Parallel downloads" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <NumberBox SpinButtonPlacementMode="Compact" Minimum="1" Maximum="8" Value="4"/>
                        <ToggleSwitch Header="Keep old versions" OnContent="On" OffContent="Off"/>
                    </StackPanel>
                </StackPanel>

                <!-- Network -->
                <StackPanel x:Name="NetworkPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsNetwork">
                    <TextBlock Text="Network" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Local Domain" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="LocalDomainBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <ToggleSwitch x:Name="AutoTlsToggle" Header="Auto TLS" OnContent="On" OffContent="Off"/>
                        <TextBlock Text="Proxy Port" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <NumberBox x:Name="ProxyPortBox" SpinButtonPlacementMode="Compact" Minimum="1" Maximum="65535"/>
                        <TextBlock Text="Tunnel Provider" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="TunnelProviderBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <TextBlock Text="Relay Server" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="RelayServerBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Cells -->
                <StackPanel x:Name="CellsPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsCells">
                    <TextBlock Text="Isolation (Cells)" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <ToggleSwitch x:Name="CellsEnabledToggle" Header="Enable by default" OnContent="On" OffContent="Off"/>
                        <TextBlock Text="Default Memory Limit" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="MemoryLimitBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <TextBlock Text="Default CPU Limit" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="CpuLimitBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <ToggleSwitch x:Name="NetworkIsolationToggle" Header="Network isolation" OnContent="On" OffContent="Off"/>
                        <TextBlock Text="Backend: AppContainer (Windows)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Deploy -->
                <StackPanel x:Name="DeployPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsDeploy">
                    <TextBlock Text="Deploy" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Provider" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="DeployProviderBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <TextBlock Text="SSH Key" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="SshKeyBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <TextBlock Text="Container Runtime" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="ContainerRuntimeBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <TextBlock Text="Registry" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="RegistryBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <ToggleSwitch x:Name="AutoGenerateToggle" Header="Auto-generate on save" OnContent="On" OffContent="Off"/>
                    </StackPanel>
                </StackPanel>

                <!-- AI (Provider + Autonomy + BYOM combined) -->
                <StackPanel x:Name="AIPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsAI">
                    <TextBlock Text="AI Configuration" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>

                    <!-- Provider -->
                    <Border Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Provider" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            <ComboBox x:Name="AIProviderCombo" Width="300" AutomationProperties.AutomationId="AIProviderSelector"/>
                            <ToggleSwitch x:Name="ProactiveSuggestionsToggle" Header="Proactive suggestions" OnContent="On" OffContent="Off"/>
                            <ToggleSwitch x:Name="AutoApplySafeToggle" Header="Auto-apply safe fixes" OnContent="On" OffContent="Off"/>
                            <ToggleSwitch x:Name="IncludeLogsToggle" Header="Include logs in context" OnContent="On" OffContent="Off"/>
                            <TextBlock Text="Max Context Size" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <NumberBox x:Name="MaxContextBox" SpinButtonPlacementMode="Compact" Minimum="512" Maximum="32768"/>
                        </StackPanel>
                    </Border>

                    <!-- Autonomy -->
                    <Border Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Autonomy Level" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            <ComboBox x:Name="AutonomyLevelCombo" Width="300" AutomationProperties.AutomationId="AutonomyLevelSelector"/>
                            <StackPanel Spacing="6" Margin="0,8,0,0">
                                <TextBlock Text="• suggest-only — AI proposes, user applies" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="• auto-apply-safe — Non-destructive auto-apply" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="• confirm-dangerous — Waits for confirmation" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="• full-autonomous — AI acts independently" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- BYOM -->
                    <Border Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Bring Your Own Model (BYOM)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Connect any OpenAI-compatible endpoint." FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="Custom Endpoint URL" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="CustomEndpointBox" PlaceholderText="https://api.example.com/v1"
                                     Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                            <TextBlock Text="API Key" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <PasswordBox x:Name="CustomApiKeyBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                            <TextBlock Text="Model Name" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="CustomModelBox" PlaceholderText="gpt-4, llama-3.3-70b, etc."
                                     Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                            <Button Content="Test Connection" Padding="16,8"
                                    Background="{StaticResource AccentPrimary}" Foreground="White" CornerRadius="6"
                                    AutomationProperties.AutomationId="TestConnectionButton"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Theme -->
                <StackPanel x:Name="ThemePanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsTheme">
                    <TextBlock Text="Theme" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Mode" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="ThemeModeCombo" Width="200">
                            <ComboBoxItem Content="Dark" IsSelected="True"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="System"/>
                        </ComboBox>
                        <TextBlock Text="Accent Color" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="AccentColorBox" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"/>
                        <TextBlock Text="Border Radius" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <Slider x:Name="RadiusSlider" Minimum="0" Maximum="20" Value="8" Width="200" HorizontalAlignment="Left"/>
                        <TextBlock Text="Font Size" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <NumberBox x:Name="FontSizeBox" SpinButtonPlacementMode="Compact" Minimum="10" Maximum="20" Value="13"/>
                        <TextBlock Text="Sidebar Width" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <Slider x:Name="SidebarWidthSlider" Minimum="180" Maximum="320" Value="240" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>

                <!-- About -->
                <StackPanel x:Name="AboutPanel" Visibility="Collapsed" Spacing="16" AutomationProperties.AutomationId="SettingsAbout">
                    <TextBlock Text="About" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="⚡ rawenv" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentPrimary}"/>
                    <TextBlock Text="Native dev environments. Zero dependencies. One binary." FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="Version 0.1.0" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="Built with Zig 0.15 · WinUI 3" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="MIT License" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    <HyperlinkButton Content="GitHub Repository" NavigateUri="https://github.com/juslintek/rawenv"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
