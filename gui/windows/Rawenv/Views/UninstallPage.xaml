<Page
    x:Class="Rawenv.Views.UninstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Uninstall rawenv" Style="{StaticResource TitleTextBlockStyle}" AutomationProperties.AutomationId="UninstallTitle"/>
        <StackPanel Grid.Row="1" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="This will remove rawenv and all managed runtimes from your system." TextWrapping="Wrap" AutomationProperties.AutomationId="UninstallDescription"/>
            <CheckBox Content="Remove store (~/.rawenv/store/)" AutomationProperties.AutomationId="UninstallRemoveStore"/>
            <CheckBox Content="Remove configuration files" AutomationProperties.AutomationId="UninstallRemoveConfig"/>
            <CheckBox Content="Remove PATH modifications" IsChecked="True" AutomationProperties.AutomationId="UninstallRemovePath"/>
        </StackPanel>
        <Button Grid.Row="2" Content="Uninstall" Style="{StaticResource AccentButtonStyle}" AutomationProperties.AutomationId="UninstallButton"/>
    </Grid>
</Page>
