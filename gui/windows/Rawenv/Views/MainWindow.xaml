<Window
    x:Class="Rawenv.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="rawenv">
    <Grid RequestedTheme="Dark" Background="#0f0f14">
        <NavigationView x:Name="NavView"
                        AutomationProperties.AutomationId="MainNavigation"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="NavView_SelectionChanged"
                        Background="#16161e"
                        RequestedTheme="Dark">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#0f0f14"/>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#16161e"/>
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="Dashboard" AutomationProperties.AutomationId="NavDashboard">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="AI Chat" Tag="AIChat" AutomationProperties.AutomationId="NavAIChat">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8BD;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Connections" Tag="Connections" AutomationProperties.AutomationId="NavConnections">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE703;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Deploy" Tag="Deploy" AutomationProperties.AutomationId="NavDeploy">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE896;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Tunnel" Tag="Tunnel" AutomationProperties.AutomationId="NavTunnel">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE774;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Projects" Tag="Projects" AutomationProperties.AutomationId="NavProjects">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8B7;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Installer" Tag="Installer" AutomationProperties.AutomationId="NavInstaller">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE896;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Uninstall" Tag="Uninstall" AutomationProperties.AutomationId="NavUninstall">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE74D;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings" AutomationProperties.AutomationId="NavSettings">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="ContentFrame" AutomationProperties.AutomationId="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
