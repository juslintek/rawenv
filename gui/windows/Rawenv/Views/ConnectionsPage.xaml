<Page
    x:Class="Rawenv.Views.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Rawenv.Models"
    RequestedTheme="Dark"
    Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0f0f14"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#16161e"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#1e1e2a"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentSuccess" Color="#34d399"/>
        <SolidColorBrush x:Key="AccentInfo" Color="#60a5fa"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e2e4f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8b8da6"/>
        <SolidColorBrush x:Key="BorderDefault" Color="#2a2a3a"/>
    </Page.Resources>

    <Grid Background="{StaticResource BgPrimary}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Connections" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                       AutomationProperties.AutomationId="ConnectionsTitle"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Mode:" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <ComboBox x:Name="ModeSelector" Width="140" SelectionChanged="ModeSelector_Changed"
                          AutomationProperties.AutomationId="ConnectionsModeSelector">
                    <ComboBoxItem Content="Local" IsSelected="True"/>
                    <ComboBoxItem Content="Proxy"/>
                    <ComboBoxItem Content="Tunnel"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Info Banner -->
        <Border Grid.Row="1" Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
            <TextBlock x:Name="ModeDescription" FontSize="12" Foreground="{StaticResource TextSecondary}"
                       Text="Local mode: Services connect directly via localhost ports."/>
        </Border>

        <!-- Connection Cards -->
        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Connections}" Background="Transparent" Margin="0,16,0,0"
                  AutomationProperties.AutomationId="ConnectionsList">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Connection">
                    <Border Background="#16161e" CornerRadius="8" Padding="16" Margin="0,4"
                            BorderBrush="#2a2a3a" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind EnvVar}" FontWeight="SemiBold" FontFamily="Consolas" FontSize="13" Foreground="#e2e4f0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#8b8da6">
                                    <Run Text="Original: "/><Run Text="{x:Bind Original}"/>
                                </TextBlock>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#60a5fa">
                                    <Run Text="Local: "/><Run Text="{x:Bind Local}"/>
                                </TextBlock>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#1e1e2a" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Badge}" FontSize="11" Foreground="#34d399"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
