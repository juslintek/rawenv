<Page
    x:Class="Rawenv.Views.AIChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Rawenv.Models"
    RequestedTheme="Dark"
    Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0f0f14"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#16161e"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#1e1e2a"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentSuccess" Color="#34d399"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e2e4f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8b8da6"/>
        <SolidColorBrush x:Key="BorderDefault" Color="#2a2a3a"/>
        <SolidColorBrush x:Key="UserBubble" Color="#2d2d5e"/>
        <SolidColorBrush x:Key="AssistantBubble" Color="#1e1e2a"/>
    </Page.Resources>

    <Grid Background="{StaticResource BgPrimary}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with provider selector -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="AI Chat" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                       AutomationProperties.AutomationId="AIChatTitle"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Provider:" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <ComboBox x:Name="ProviderSelector" Width="200" AutomationProperties.AutomationId="AIChatProviderSelector">
                    <ComboBoxItem Content="Auto (Groq → Cerebras → CF)" IsSelected="True"/>
                    <ComboBoxItem Content="Groq"/>
                    <ComboBoxItem Content="Cerebras"/>
                    <ComboBoxItem Content="Cloudflare Workers AI"/>
                    <ComboBoxItem Content="Ollama (local)"/>
                    <ComboBoxItem Content="Custom (BYOM)"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Chat Messages -->
        <ListView x:Name="MessagesList" Grid.Row="1" Background="Transparent"
                  ItemsSource="{x:Bind ViewModel.Messages}"
                  AutomationProperties.AutomationId="AIChatMessages">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:AIMessage">
                    <Border Padding="12" Margin="0,4"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.6">
                                <Run Text="{x:Bind Role}"/>
                            </TextBlock>
                            <TextBlock Text="{x:Bind Text}" TextWrapping="Wrap" FontSize="13" Foreground="#e2e4f0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask rawenv AI anything…"
                         Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderDefault}"
                         KeyDown="Input_KeyDown"
                         AutomationProperties.AutomationId="AIChatInput"/>
                <Button Grid.Column="1" Content="Send" Padding="16,8"
                        Background="{StaticResource AccentPrimary}" Foreground="White" CornerRadius="6"
                        Command="{x:Bind ViewModel.SendCommand}"
                        AutomationProperties.AutomationId="AIChatSendButton"/>
            </Grid>
        </Border>
    </Grid>
</Page>
