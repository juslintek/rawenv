<Page
    x:Class="Rawenv.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Rawenv.Models"
    RequestedTheme="Dark"
    Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0f0f14"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#16161e"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#1e1e2a"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentSuccess" Color="#34d399"/>
        <SolidColorBrush x:Key="AccentError" Color="#f87171"/>
        <SolidColorBrush x:Key="AccentWarning" Color="#fbbf24"/>
        <SolidColorBrush x:Key="AccentInfo" Color="#60a5fa"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e2e4f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8b8da6"/>
        <SolidColorBrush x:Key="BorderDefault" Color="#2a2a3a"/>
    </Page.Resources>

    <Grid Background="{StaticResource BgPrimary}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Start/Stop All -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"
                       AutomationProperties.AutomationId="DashboardTitle"/>
            <Button Grid.Column="1" Content="Start All" Padding="12,6" Margin="0,0,8,0"
                    Background="{StaticResource AccentSuccess}" Foreground="White" CornerRadius="6"
                    Click="StartAll_Click" AutomationProperties.AutomationId="StartAllButton"/>
            <Button Grid.Column="2" Content="Stop All" Padding="12,6"
                    Background="{StaticResource AccentError}" Foreground="White" CornerRadius="6"
                    Click="StopAll_Click" AutomationProperties.AutomationId="StopAllButton"/>
        </Grid>

        <!-- Stats Cards -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,16,0,16">
            <Border Background="{StaticResource BgSecondary}" CornerRadius="10" Padding="16" Width="190" Height="88"
                    AutomationProperties.AutomationId="StatsCardServices">
                <StackPanel>
                    <TextBlock Text="SERVICES" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock x:Name="RunningCount" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource BgSecondary}" CornerRadius="10" Padding="16" Width="190" Height="88"
                    AutomationProperties.AutomationId="StatsCardCPU">
                <StackPanel>
                    <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock x:Name="CpuLabel" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                    <ProgressBar x:Name="CpuBar" Maximum="100" Height="6" Foreground="{StaticResource AccentSuccess}" Background="{StaticResource BgTertiary}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource BgSecondary}" CornerRadius="10" Padding="16" Width="190" Height="88"
                    AutomationProperties.AutomationId="StatsCardMemory">
                <StackPanel>
                    <TextBlock Text="MEMORY" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock x:Name="MemLabel" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                    <ProgressBar x:Name="MemBar" Maximum="100" Height="6" Foreground="{StaticResource AccentPrimary}" Background="{StaticResource BgTertiary}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource BgSecondary}" CornerRadius="10" Padding="16" Width="190" Height="88"
                    AutomationProperties.AutomationId="StatsCardUptime">
                <StackPanel>
                    <TextBlock Text="UPTIME" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="2h 14m" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Service List Header -->
        <TextBlock Grid.Row="2" Text="Services" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>

        <!-- Service List with Start/Stop buttons -->
        <ListView Grid.Row="3" x:Name="ServicesList" Background="Transparent"
                  AutomationProperties.AutomationId="DashboardServicesList" Margin="0,0,0,12">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Service">
                    <Grid Padding="8,10" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="{x:Bind Status, Converter={StaticResource StatusColorConverter}}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind Icon}" FontSize="16" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" Foreground="#e2e4f0"/>
                            <TextBlock FontSize="11" Foreground="#8b8da6">
                                <Run Text="v"/><Run Text="{x:Bind Version}"/>
                                <Run Text=" · :"/><Run Text="{x:Bind Port}"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="{x:Bind Cpu}" FontFamily="Consolas" FontSize="12" Foreground="#8b8da6" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind Mem}" FontFamily="Consolas" FontSize="12" Foreground="#8b8da6" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="{x:Bind Uptime}" FontFamily="Consolas" FontSize="12" Foreground="#8b8da6" VerticalAlignment="Center"/>
                        <Button Grid.Column="6" Tag="{x:Bind Name}" Click="ToggleService_Click" Padding="8,4" CornerRadius="4"
                                Content="{x:Bind Status}" FontSize="11" VerticalAlignment="Center"
                                AutomationProperties.AutomationId="ServiceToggleButton"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Tabs -->
        <Pivot Grid.Row="4" AutomationProperties.AutomationId="DashboardTabs">
            <PivotItem Header="Logs" AutomationProperties.AutomationId="TabLogs">
                <ListView ItemsSource="{x:Bind ViewModel.Logs}" Background="Transparent" AutomationProperties.AutomationId="LogsList">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:LogEntry">
                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#8b8da6">
                                <Run Text="{x:Bind Time}" Foreground="#4a4b5e"/><Run Text="  "/><Run Text="{x:Bind Msg}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>
            <PivotItem Header="Config" AutomationProperties.AutomationId="TabConfig">
                <ScrollViewer>
                    <TextBlock Text="{x:Bind ViewModel.ConfigContent}" FontFamily="Consolas" FontSize="13"
                               Foreground="#8b8da6" AutomationProperties.AutomationId="ConfigText"/>
                </ScrollViewer>
            </PivotItem>
            <PivotItem Header="Connections" AutomationProperties.AutomationId="TabConnection">
                <ListView ItemsSource="{x:Bind ViewModel.Connections}" Background="Transparent" AutomationProperties.AutomationId="ConnectionsList">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Connection">
                            <StackPanel Padding="4,8">
                                <TextBlock Text="{x:Bind EnvVar}" FontWeight="SemiBold" FontFamily="Consolas" FontSize="12" Foreground="#e2e4f0"/>
                                <TextBlock Text="{x:Bind Local}" FontFamily="Consolas" FontSize="11" Foreground="#8b8da6"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>
            <PivotItem Header="Cell" AutomationProperties.AutomationId="TabCell">
                <TextBlock Text="{x:Bind ViewModel.CellInfo}" Foreground="#8b8da6" FontSize="13"
                           AutomationProperties.AutomationId="CellInfoText"/>
            </PivotItem>
            <PivotItem Header="Backups" AutomationProperties.AutomationId="TabBackups">
                <TextBlock Text="{x:Bind ViewModel.BackupInfo}" Foreground="#8b8da6" FontSize="13"
                           AutomationProperties.AutomationId="BackupInfoText"/>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
