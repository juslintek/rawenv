FROM debian:13-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    valac \
    gcc \
    meson \
    ninja-build \
    libgtk-4-dev \
    libadwaita-1-dev \
    libjson-glib-dev \
    xvfb \
    at-spi2-core \
    dbus \
    python3 \
    python3-pip \
    python3-gi \
    gir1.2-gtk-3.0 \
    gir1.2-gtk-4.0 \
    gir1.2-adw-1 \
    gir1.2-atspi-2.0 \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages dogtail pytest

WORKDIR /app

COPY gui/linux/ /app/gui/linux/
COPY shared/mock-data.json /app/shared/mock-data.json

WORKDIR /app/gui/linux

RUN meson setup build && ninja -C build

ENV DISPLAY=:99
ENV GTK_A11Y=atspi
ENV DBUS_SESSION_BUS_ADDRESS=autolaunch:

CMD ["sh", "-c", "\
    Xvfb :99 -screen 0 1280x1024x24 & \
    sleep 1 && \
    dbus-run-session -- sh -c '\
        meson test -C build && \
        cd tests/e2e && \
        python3 -m pytest -v \
    '"]
