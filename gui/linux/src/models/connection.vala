public class Rawenv.Connection : Object {
    public string env_var { get; set; default = ""; }
    public string original { get; set; default = ""; }
    public string local { get; set; default = ""; }
    public string mode { get; set; default = ""; }
    public string badge { get; set; default = ""; }
    public string proxy { get; set; default = ""; }
    public string alternative { get; set; default = ""; }
}
