# Maintainer: rawenv team
pkgname=rawenv
pkgver=VERSION
pkgrel=1
pkgdesc="Universal development environment manager"
arch=('x86_64' 'aarch64')
url="https://github.com/rawenv/rawenv"
license=('MIT')
makedepends=('zig>=0.14')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/rawenv/rawenv/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SHA256_SOURCE')

build() {
  cd "${pkgname}-${pkgver}"
  zig build -Doptimize=ReleaseSafe
}

check() {
  cd "${pkgname}-${pkgver}"
  zig build test
}

package() {
  cd "${pkgname}-${pkgver}"
  install -Dm755 zig-out/bin/rawenv "${pkgdir}/usr/bin/rawenv"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}
